# ============================================================
# Blog Pipeline - Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# ============================================================

# --- Groq LLM ---
# Obtain your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Firecrawl (Web Scraping) ---
# Obtain your key at: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-your_firecrawl_api_key_here

# --- Database ---
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/blog_pipeline

# --- Pipeline Settings ---
MAX_CRITIC_ATTEMPTS=5
PASS_SCORE_THRESHOLD=85

# --- Logging ---
LOG_LEVEL=INFO        # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_DIR=logs

# --- App Environment ---
ENVIRONMENT=development   # development | production
